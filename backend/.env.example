# 万象书屋后端环境变量模板
# 复制为 .env 后填入, 或直接通过 systemd / docker 注入

# HTTP 端口, 默认 3000
PORT=3000

# SQLite 数据库文件路径, 默认 backend/data/wanxiang.db
# DB_PATH=/var/wanxiang/wanxiang.db

# 管理员初始密码 (>=8 chars).
# 生产环境必须设, 未设置时会拒绝启动 (若 NODE_ENV=production).
# 一旦首次启动落库就不再从这里读, 之后改密码要走 admin 面板或 scripts/reset-admin-password.js
ADMIN_INITIAL_PASSWORD=change-me-please-long-enough

# 生产环境 = production, 强制启用所有安全保护 (要求密码, 拒不安全 cookie 等)
# NODE_ENV=production

# HTTPS 反代后置 cookie secure flag (nginx 代理 HTTPS 时设为 1)
# SECURE_COOKIE=1

# 即使 NODE_ENV 不是 production, 也强制要求 ADMIN_INITIAL_PASSWORD
# REQUIRE_ADMIN_PWD=1

# bcrypt 工作因子 (4~14, 默认 10).
# 经验值:
#   - 1 核 1G VPS: cost=8 (单次 hash ~30ms, 登录密集时 CPU 不打满)
#   - 4 核及以上服务器: cost=10 (单次 ~200~600ms, 兼顾安全与性能)
#   - 高安全要求金融/政企: cost=12 (单次几秒, 抗暴力破解最强)
#   - CI / 单元测试: cost=4 (~5ms, 测试快)
# 改完此值后必须用 reset-admin-password.js 重新设密码生效, 旧 hash 仍是旧 cost.
# BCRYPT_COST=10

# 日志级别: debug / info / warn / error, 默认 info
# LOG_LEVEL=info

# === 万象书屋 v2: 设备 token HMAC secret ===
# 必须 32+ 字符随机串, 用于给设备签发 token, 防 device_id 被伪造.
# 生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 一旦上线不可更改 (改了所有用户的 token 会失效, 必须重新 register).
# DEVICE_TOKEN_SECRET=

# === 备份策略 ===
# 本地保留天数, 默认 7 天
# BACKUP_RETENTION_DAYS=7
# 备份完成后 POST 通知此 URL (用户可写脚本拉取备份文件上传 OSS/COS/S3)
# 通知 body: { ok, target, sha256, size, ts }
# BACKUP_WEBHOOK_URL=https://your-uploader.example.com/backup-notify

