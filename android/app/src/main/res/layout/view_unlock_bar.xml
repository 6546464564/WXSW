<?xml version="1.0" encoding="utf-8"?>
<!--
万象书屋: 阅读器顶部纯净阅读倒计时条.

显示规则:
  - 用户处于解锁窗口内 → 显示, 实时倒计时
  - 解锁过期 → 隐藏 (节省屏幕空间)
  - showCountdownBar=false (后端配置) → 始终隐藏

布局:
  [纯净阅读 25:32]   [+ 看广告续 30 分钟]
   左侧倒计时        右侧主推按钮 (冷却中置灰)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/unlock_bar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="top"
    android:background="#CC000000"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="14dp"
    android:paddingVertical="8dp"
    android:visibility="gone"
    tools:visibility="visible">

    <TextView
        android:id="@+id/unlock_bar_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/unlock_bar_label"
        android:textColor="#FFFFFFFF"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/unlock_bar_remaining"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:textColor="#FFEACE3F"
        android:textSize="14sp"
        android:textStyle="bold"
        tools:text="25:32" />

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/unlock_bar_button"
        android:layout_width="wrap_content"
        android:layout_height="34dp"
        android:background="@drawable/bg_book_finished_button_primary"
        android:minWidth="0dp"
        android:paddingHorizontal="14dp"
        android:textColor="#FFFFFFFF"
        android:textSize="13sp"
        tools:text="+ 看广告续 30 分钟" />
</LinearLayout>
