<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_cosmic_discover"
    android:orientation="vertical">

    <!-- 顶部：玻璃质感顶栏 + 星系 Logo + Tab + 搜索
         topBarContainer: 真机上需要给整个顶栏加 status bar inset (paddingTop),
         否则刘海屏 / 挖孔屏 / 普通状态栏会盖住 Tab, 导致 男生/女生/出版 点不到 -->
    <LinearLayout
        android:id="@+id/topBarContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_cosmic_top_bar"
        android:elevation="5dp"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <TextView
                android:id="@+id/tabMale"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="?selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="@string/bs_male"
                android:textColor="@color/wanxiang_text_primary"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tabFemale"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="?selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="@string/bs_female"
                android:textColor="@color/wanxiang_text_secondary"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/tabPublish"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="?selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="@string/bs_publish"
                android:textColor="@color/wanxiang_text_secondary"
                android:textSize="17sp" />

            <Space
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/ivSearch"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="@string/search"
                android:focusable="true"
                android:padding="6dp"
                android:src="@drawable/ic_search"
                app:tint="@color/wanxiang_primary" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:id="@+id/tabIndicator"
        android:layout_width="20dp"
        android:layout_height="3dp"
        android:layout_marginStart="22dp"
        android:layout_marginTop="-6dp"
        android:background="@drawable/bs_section_indicator" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/refreshLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/bookStoreScroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:scrollbars="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="24dp">

                <!-- 2 个宣传卡 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardRank"
                        android:layout_width="0dp"
                        android:layout_height="84dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bs_banner_rank_bg"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:paddingHorizontal="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/bs_rank"
                                android:textColor="@color/wanxiang_text_primary"
                                android:textSize="17sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/bs_rank_sub"
                                android:textColor="@color/wanxiang_text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardLibrary"
                        android:layout_width="0dp"
                        android:layout_height="84dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bs_banner_library_bg"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:paddingHorizontal="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/bs_library"
                                android:textColor="@color/wanxiang_text_primary"
                                android:textSize="17sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/bs_library_sub"
                                android:textColor="@color/wanxiang_text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- 今日必读 -->
                <include
                    android:id="@+id/sectionMustRead"
                    layout="@layout/item_book_store_section_header" />

                <FrameLayout
                    android:id="@+id/heroSlot"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginTop="6dp"
                    app:cardBackgroundColor="@color/wanxiang_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp">

                    <GridLayout
                        android:id="@+id/gridMustRead"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="4"
                        android:padding="8dp" />
                </androidx.cardview.widget.CardView>

                <!-- 完本精选 -->
                <include
                    android:id="@+id/sectionComplete"
                    layout="@layout/item_book_store_section_header" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginTop="6dp"
                    app:cardBackgroundColor="@color/wanxiang_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp">

                    <GridLayout
                        android:id="@+id/gridComplete"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="4"
                        android:padding="8dp" />
                </androidx.cardview.widget.CardView>

                <!-- 推荐榜 -->
                <include
                    android:id="@+id/sectionRecommend"
                    layout="@layout/item_book_store_section_header" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginTop="6dp"
                    app:cardBackgroundColor="@color/wanxiang_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp">

                    <GridLayout
                        android:id="@+id/gridRanked"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:padding="8dp" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="20dp"
                    android:textColor="@color/wanxiang_text_secondary"
                    android:textSize="13sp"
                    android:visibility="gone"
                    tools:text="加载中…"
                    tools:visibility="visible" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</LinearLayout>
