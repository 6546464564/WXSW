<?xml version="1.0" encoding="utf-8"?>
<!--
万象书屋: Android 12+ 数据提取规则.
明确禁止 cloud-backup 和 device-transfer 提取所有 App 数据,
避免用户数据 (阅读进度/书源/书架) 被自动同步到谷歌云或迁移到新设备.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
