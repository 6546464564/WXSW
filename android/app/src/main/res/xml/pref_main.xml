<?xml version="1.0" encoding="utf-8"?>
<androidx.preference.PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:divider="@color/transparent"
    app:allowDividerBelow="false">

    <io.legado.app.lib.prefs.Preference
        android:icon="@drawable/ic_cfg_source"
        android:key="txtTocRuleManage"
        android:summary="@string/config_txt_toc_rule"
        android:title="@string/txt_toc_rule"
        app:iconSpaceReserved="false" />

    <io.legado.app.lib.prefs.Preference
        android:icon="@drawable/ic_cfg_replace"
        android:key="replaceManage"
        android:summary="@string/replace_purify_desc"
        android:title="@string/replace_purify"
        app:iconSpaceReserved="false" />

    <io.legado.app.lib.prefs.Preference
        android:icon="@drawable/ic_translate"
        android:key="dictRuleManage"
        android:summary="@string/config_dict_rule"
        android:title="@string/dict_rule"
        app:iconSpaceReserved="false" />

    <!--
      万象书屋 D-18: 主题模式 UI 简化, 用"跟随系统"开关替代原 4 选项 (跟随/亮/暗/EInk).
        开 -> themeMode=0 跟随系统
        关 -> themeMode=1 强制亮色 (默认行为)
      暗色 & EInk 旧值不删除, 老用户重启后由 MyFragment 监听器统一迁移到当前开关状态.
    -->
    <io.legado.app.lib.prefs.SwitchPreference
        android:defaultValue="true"
        android:icon="@drawable/ic_cfg_theme"
        android:key="themeFollowSystem"
        android:summary="@string/theme_follow_system_summary"
        android:title="@string/theme_follow_system"
        app:iconSpaceReserved="false" />

    <!-- 万象书屋 D-18: 护眼模式. 全屏暖色滤镜 (alpha 30, 浅琥珀色), BaseActivity 统一注入 -->
    <io.legado.app.lib.prefs.SwitchPreference
        android:defaultValue="false"
        android:icon="@drawable/ic_brightness"
        android:key="eyeCareMode"
        android:summary="@string/eye_care_mode_summary"
        android:title="@string/eye_care_mode"
        app:iconSpaceReserved="false" />

    <io.legado.app.lib.prefs.PreferenceCategory
        android:key="settingCategory"
        android:title="@string/setting"
        app:allowDividerAbove="true"
        app:allowDividerBelow="false"
        app:iconSpaceReserved="false">

        <io.legado.app.lib.prefs.Preference
            android:icon="@drawable/ic_cfg_theme"
            android:key="theme_setting"
            android:summary="@string/theme_setting_s"
            android:title="@string/theme_setting"
            app:iconSpaceReserved="false" />

        <io.legado.app.lib.prefs.Preference
            android:icon="@drawable/ic_cfg_other"
            android:key="setting"
            android:summary="@string/other_setting_s"
            android:title="@string/other_setting"
            app:allowDividerBelow="false"
            app:iconSpaceReserved="false" />

    </io.legado.app.lib.prefs.PreferenceCategory>

    <io.legado.app.lib.prefs.PreferenceCategory
        android:key="aboutCategory"
        android:title="@string/other"
        app:allowDividerAbove="true"
        app:allowDividerBelow="false"
        app:iconSpaceReserved="false"
        app:layout="@layout/view_preference_category">

        <io.legado.app.lib.prefs.Preference
            android:icon="@drawable/ic_bookmark"
            android:key="bookmark"
            android:summary="@string/all_bookmark"
            android:title="@string/bookmark"
            app:iconSpaceReserved="false" />

        <io.legado.app.lib.prefs.Preference
            android:icon="@drawable/ic_history"
            android:key="readRecord"
            android:summary="@string/read_record_summary"
            android:title="@string/read_record"
            app:iconSpaceReserved="false" />

        <io.legado.app.lib.prefs.Preference
            android:icon="@drawable/ic_folder_outline"
            android:key="fileManage"
            android:summary="@string/file_manage_summary"
            android:title="@string/file_manage"
            app:allowDividerBelow="false"
            app:iconSpaceReserved="false" />

    </io.legado.app.lib.prefs.PreferenceCategory>

    <!-- 万象书屋: 上架合规必备的"关于 / 法律 / 反馈" 区域 -->
    <io.legado.app.lib.prefs.PreferenceCategory
        android:key="legalCategory"
        android:title="@string/about_legal_category"
        app:allowDividerAbove="true"
        app:allowDividerBelow="false"
        app:iconSpaceReserved="false"
        app:layout="@layout/view_preference_category">

        <io.legado.app.lib.prefs.Preference
            android:icon="@drawable/ic_help"
            android:key="legal_about"
            android:summary="@string/about_legal_summary"
            android:title="@string/about_title"
            app:iconSpaceReserved="false" />

        <io.legado.app.lib.prefs.Preference
            android:key="legal_privacy"
            android:title="@string/about_privacy_policy"
            app:iconSpaceReserved="false" />

        <io.legado.app.lib.prefs.Preference
            android:key="legal_user_agreement"
            android:title="@string/about_user_agreement"
            app:iconSpaceReserved="false" />

        <io.legado.app.lib.prefs.Preference
            android:key="legal_collect_list"
            android:title="@string/about_collect_list"
            app:iconSpaceReserved="false" />

        <io.legado.app.lib.prefs.Preference
            android:key="legal_sdk_list"
            android:title="@string/about_sdk_list"
            app:iconSpaceReserved="false" />

        <io.legado.app.lib.prefs.Preference
            android:key="legal_open_source"
            android:title="@string/about_open_source"
            app:iconSpaceReserved="false" />

        <io.legado.app.lib.prefs.Preference
            android:icon="@drawable/ic_bug_report"
            android:key="legal_feedback"
            android:summary="@string/about_feedback_summary"
            android:title="@string/about_feedback"
            app:iconSpaceReserved="false" />

        <io.legado.app.lib.prefs.Preference
            android:key="legal_account_delete"
            android:summary="@string/about_account_delete_summary"
            android:title="@string/about_account_delete"
            app:allowDividerBelow="false"
            app:iconSpaceReserved="false" />

    </io.legado.app.lib.prefs.PreferenceCategory>

</androidx.preference.PreferenceScreen>