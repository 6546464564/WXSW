<?xml version="1.0" encoding="utf-8"?>
<!-- 万象书屋: 意见反馈页"提交"按钮背景 (品牌琥珀棕圆角胶囊),
     与 colors.xml 里 wanxiang_primary 一致, 整体视觉统一为暖米色调.
     选中态略微加深用作 ripple, disabled 态保留同色减半透明. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="#80B8956B" />
            <corners android:radius="25dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#9A7F58" />
            <corners android:radius="25dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#B8956B" />
            <corners android:radius="25dp" />
        </shape>
    </item>
</selector>
