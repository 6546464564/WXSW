<?xml version="1.0" encoding="utf-8"?>
<!--
  万象书屋: 品牌色胶囊按钮背景, 用于空态/CTA 按钮.
  - 圆角 22dp 形成胶囊形 (高度 40dp 时正好 = height/2)
  - default 实色, pressed 微暗反馈
  - 不依赖 Material3 主题, 任何 Activity 都能用
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#A38062" />
            <corners android:radius="22dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/wanxiang_brand_primary" />
            <corners android:radius="22dp" />
        </shape>
    </item>
</selector>
