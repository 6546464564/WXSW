<?xml version="1.0" encoding="utf-8"?>
<!--
  万象书屋 D-17 (THEME-1): 书城页背景渐变.
  颜色引用 @color/bs_bg_gradient_*, values-night 自动切换为暗色变体.
  原 hex 值 (#EDE4D6/#FAF6EF) 已抽到命名色 colors.xml.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="135"
        android:endColor="@color/bs_bg_gradient_end"
        android:startColor="@color/bs_bg_gradient_start"
        android:type="linear" />
</shape>
