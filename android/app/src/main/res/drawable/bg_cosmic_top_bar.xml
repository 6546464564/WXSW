<?xml version="1.0" encoding="utf-8"?>
<!-- 顶栏：半透明纸感 + 淡金描边（仿毛玻璃层次） -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#CCF9F6F0" />
            <corners
                android:bottomLeftRadius="16dp"
                android:bottomRightRadius="16dp" />
        </shape>
    </item>
    <item
        android:bottom="0dp"
        android:left="0dp"
        android:right="0dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="#55C9A86C" />
            <corners
                android:bottomLeftRadius="16dp"
                android:bottomRightRadius="16dp" />
        </shape>
    </item>
</layer-list>
