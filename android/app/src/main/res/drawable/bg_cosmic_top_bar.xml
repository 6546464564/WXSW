<?xml version="1.0" encoding="utf-8"?>
<!--
  万象书屋 D-17 (THEME-1): 顶栏纸感半透明 + 描边.
  颜色 @color/bs_topbar_*, values-night 切换为暗色版.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bs_topbar_solid" />
            <corners
                android:bottomLeftRadius="16dp"
                android:bottomRightRadius="16dp" />
        </shape>
    </item>
    <item
        android:bottom="0dp"
        android:left="0dp"
        android:right="0dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="@color/bs_topbar_stroke" />
            <corners
                android:bottomLeftRadius="16dp"
                android:bottomRightRadius="16dp" />
        </shape>
    </item>
</layer-list>
